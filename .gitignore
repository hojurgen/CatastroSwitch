# Committed workspace configuration
.vscode/*
!.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/mcp.json
!.vscode/settings.json
!.vscode/tasks.json

# Node / JavaScript transient output
node_modules/
out/
dist/
coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python helper-script transient output
__pycache__/
*.py[cod]
.coverage
htmlcov/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local environment files
.env
.env.*
!.env.example
!.env.sample

# IDE and editor state
.idea/
.vs/
.vscode-test/
.history/
*.local.code-workspace

# Temporary files and caches
.cache/
.tmp/
temp/
tmp/
*.tmp
*.bak
*.orig
*.rej
*.log

# Packaged extension output
*.vsix

# OS files
.DS_Store
Thumbs.db
Desktop.ini
