#!/bin/sh

hook_dir="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
control_repo_root="$(CDPATH= cd -- "$hook_dir/.." && pwd)"
repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"

if [ -z "$repo_root" ]; then
  exit 0
fi

powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File "$control_repo_root/scripts/runtime-fork-git-hook.ps1" -HookName pre-commit -ForkRoot "$repo_root"
exit $?
