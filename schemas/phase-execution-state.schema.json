{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catastroswitch.local/schemas/phase-execution-state.schema.json",
  "title": "CatastroSwitch Phase Execution State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "updatedAt",
    "phases"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "activePhaseId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/phase"
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "path"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "completion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "completedAt",
        "summary"
      ],
      "properties": {
        "completedAt": {
          "type": "string",
          "format": "date-time"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          }
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z]{2,}-[0-9]{3}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "not-started",
            "in-progress",
            "blocked",
            "completed"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        },
        "completion": {
          "$ref": "#/$defs/completion"
        }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status",
        "tasks"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "not-started",
            "in-progress",
            "blocked",
            "completed"
          ]
        },
        "summary": {
          "type": "string"
        },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/task"
          }
        }
      }
    }
  }
}