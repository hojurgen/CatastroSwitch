{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CatastroSwitch phase execution state",
  "type": "object",
  "required": [
    "version",
    "phaseId",
    "phaseBranch",
    "phaseMode",
    "phaseStatus",
    "executionLock",
    "planner",
    "tasks",
    "gatekeeper"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 3
    },
    "phaseId": {
      "type": "string",
      "enum": [
        "F0",
        "F1",
        "F2",
        "F3",
        "F4"
      ]
    },
    "phaseBranch": {
      "type": "string"
    },
    "phaseMode": {
      "type": "string",
      "enum": [
        "fresh_implementation",
        "partial_implementation",
        "reimplementation"
      ]
    },
    "phaseStatus": {
      "type": "string",
      "enum": [
        "planning",
        "coding",
        "reviewing",
        "gatekeeper",
        "pass",
        "error"
      ]
    },
    "executionLock": {
      "$ref": "#/definitions/executionLock"
    },
    "planner": {
      "$ref": "#/definitions/planner"
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/task"
      }
    },
    "gatekeeper": {
      "$ref": "#/definitions/gatekeeper"
    }
  },
  "definitions": {
    "parallelGroup": {
      "type": "object",
      "required": [
        "id",
        "tasks",
        "reason"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "planner": {
      "type": "object",
      "required": [
        "summary",
        "currentGaps",
        "sequentialTasks",
        "parallelGroups",
        "readyTasks"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "currentGaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sequentialTasks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "parallelGroups": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/parallelGroup"
          }
        },
        "readyTasks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "review": {
      "type": "object",
      "required": [
        "outcome",
        "reasoning",
        "requiredFixes",
        "docsOrValidationGaps",
        "nextHandoffTarget"
      ],
      "properties": {
        "outcome": {
          "type": "string",
          "enum": [
            "Pending",
            "Pass",
            "Error"
          ]
        },
        "reasoning": {
          "type": "string"
        },
        "requiredFixes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "docsOrValidationGaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nextHandoffTarget": {
          "type": "string",
          "enum": [
            "Coding Agent",
            "Planner",
            "Gatekeeper",
            "None"
          ]
        }
      }
    },
    "executionLock": {
      "type": "object",
      "required": [
        "activeAgent",
        "activeTaskId",
        "allowedBranch",
        "allowedWorktree",
        "nextHandoffTarget",
        "pendingReviewForTask",
        "dirtyWorktreePolicy"
      ],
      "properties": {
        "activeAgent": {
          "type": "string",
          "enum": [
            "Orchestrator",
            "Planner",
            "Coding Agent",
            "Reviewer",
            "Gatekeeper",
            "Fork Architect",
            "None"
          ]
        },
        "activeTaskId": {
          "type": [
            "string",
            "null"
          ]
        },
        "allowedBranch": {
          "type": "string"
        },
        "allowedWorktree": {
          "type": "string"
        },
        "nextHandoffTarget": {
          "type": "string",
          "enum": [
            "Planner",
            "Coding Agent",
            "Reviewer",
            "Gatekeeper",
            "Fork Architect",
            "None"
          ]
        },
        "pendingReviewForTask": {
          "type": [
            "string",
            "null"
          ]
        },
        "dirtyWorktreePolicy": {
          "type": "string",
          "enum": [
            "only_locked_worktree_may_be_dirty",
            "clean_before_review",
            "clean_before_gatekeeper",
            "phase_pass_clean"
          ]
        }
      }
    },
    "task": {
      "type": "object",
      "required": [
        "id",
        "title",
        "status",
        "dependsOn",
        "branch",
        "filesChanged",
        "validation",
        "docsUpdated",
        "review"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "in_progress",
            "review_error",
            "review_pass",
            "done"
          ]
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "parallelGroup": {
          "type": [
            "string",
            "null"
          ]
        },
        "branch": {
          "type": "string"
        },
        "filesChanged": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validation": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "docsUpdated": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "review": {
          "$ref": "#/definitions/review"
        }
      }
    },
    "gatekeeper": {
      "type": "object",
      "required": [
        "outcome",
        "goalsChecked",
        "errors",
        "broaderRisks",
        "reasoning",
        "requiredNextAction",
        "recommendedNextPhase"
      ],
      "properties": {
        "outcome": {
          "type": "string",
          "enum": [
            "Pending",
            "Pass",
            "Error"
          ]
        },
        "goalsChecked": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "broaderRisks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reasoning": {
          "type": "string"
        },
        "requiredNextAction": {
          "type": "string"
        },
        "recommendedNextPhase": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "F0",
            "F1",
            "F2",
            "F3",
            "F4",
            null
          ]
        }
      }
    }
  }
}
