{
  "version": 1,
  "sourcePolicy": {
    "rasterIconMaster": "assets/logo.svg",
    "workbenchIconSource": "assets/logo.svg",
    "iconPreview": "assets/logo.svg"
  },
  "targets": [
    {
      "id": "win32-product-icon",
      "source": "assets/logo.svg",
      "forkRelativeOutput": "resources/win32/code.ico",
      "format": "ico",
      "sizes": [16, 20, 24, 30, 32, 36, 40, 48, 60, 64, 72, 80, 96, 128, 256],
      "notes": "Provide exact Win32 shell sizes while keeping every generated frame derived from the shared SVG icon master."
    },
    {
      "id": "win32-visualelements-70",
      "source": "assets/logo.svg",
      "forkRelativeOutput": "resources/win32/code_70x70.png",
      "format": "png",
      "size": 70,
      "notes": "Windows visual elements small tile logo generated from the shared SVG icon master."
    },
    {
      "id": "win32-visualelements-150",
      "source": "assets/logo.svg",
      "forkRelativeOutput": "resources/win32/code_150x150.png",
      "format": "png",
      "size": 150,
      "notes": "Windows visual elements medium tile logo generated from the shared SVG icon master so Windows does not surface the legacy blue branding."
    },
    {
      "id": "darwin-product-icon",
      "source": "assets/logo.svg",
      "forkRelativeOutput": "resources/darwin/code.icns",
      "format": "icns",
      "sizes": [16, 32, 64, 128, 256, 512, 1024],
      "notes": "Package from the shared SVG icon master via a staged iconset with macOS iconutil."
    },
    {
      "id": "linux-product-icon",
      "source": "assets/logo.svg",
      "forkRelativeOutput": "resources/linux/code.png",
      "format": "png",
      "size": 1024,
      "notes": "Square Linux desktop icon."
    },
    {
      "id": "workbench-code-icon",
      "source": "assets/logo.svg",
      "forkRelativeOutput": "src/vs/workbench/browser/media/code-icon.svg",
      "format": "svg",
      "notes": "Direct SVG copy from the shared SVG icon master for the in-app workbench product icon used by title bar, getting started, update tooltip, banner, and walkthrough surfaces."
    },
    {
      "id": "server-favicon",
      "source": "assets/logo.svg",
      "forkRelativeOutput": "resources/server/favicon.ico",
      "format": "ico",
      "sizes": [16, 32, 48],
      "notes": "Server and web favicon payload generated from the shared SVG icon master."
    },
    {
      "id": "server-icon-192",
      "source": "assets/logo.svg",
      "forkRelativeOutput": "resources/server/code-192.png",
      "format": "png",
      "size": 192,
      "notes": "Server and web icon surface."
    },
    {
      "id": "server-icon-512",
      "source": "assets/logo.svg",
      "forkRelativeOutput": "resources/server/code-512.png",
      "format": "png",
      "size": 512,
      "notes": "Server and web icon surface."
    }
  ]
}
